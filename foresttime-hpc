FROM ubuntu:22.04
ARG DEBIAN_FRONTEND=noninteractive
RUN apt update
RUN apt install -y --no-install-recommends ca-certificates curl gpg software-properties-common
RUN curl -fsSL https://cloud.r-project.org/bin/linux/ubuntu/marutter_pubkey.asc | gpg --dearmor -o /usr/share/keyrings/cran.gpg
COPY <<EOF /etc/apt/sources.list.d/cran.sources
X-Repolib-Name: CRAN 
Types: deb 
URIs: https://cloud.r-project.org/bin/linux/ubuntu/ 
Suites: jammy-cran40/ 
Components: 
Signed-By: /usr/share/keyrings/cran.gpg
EOF
RUN cat  /etc/apt/sources.list.d/cran.sources
RUN apt update
RUN apt install r-base -y wget 
RUN wget "https://cran.r-project.org/src/contrib/jsonlite_2.0.0.tar.gz"
RUN R CMD INSTALL jsonlite_2.0.0.tar.gz
RUN wget "https://cran.r-project.org/src/contrib/fs_2.0.1.tar.gz"
RUN apt install -y libuv1
RUN apt install -y cmake
RUN R CMD INSTALL fs_2.0.1.tar.gz
RUN R -e "install.packages('dplyr',dependencies=TRUE, repos='http://cran.rstudio.com/')" 
RUN R -e "install.packages('nanoparquet',dependencies=TRUE, repos='http://cran.rstudio.com/')" 
RUN R -e "install.packages('purrr',dependencies=TRUE, repos='http://cran.rstudio.com/')" 
RUN R -e "install.packages('dplyr',dependencies=TRUE, repos='http://cran.rstudio.com/')" 
RUN wget "https://github.com/Evans-Ecology-Lab/forestTIME/archive/refs/tags/v2.2.0.tar.gz" -O ftime2.2.0.tar.gz
RUN R -e "install.packages('forestTIME', repos = c('https://cct-datascience.r-universe.dev', getOption('repos')))"
